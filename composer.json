{
  "name": "verysimple/vs-relink",
  "description": "Very Simple link redirection and tracking for WordPress.",
  "version": "1.3.0",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "WPSuli",
      "homepage": "https://wpsuli.hu"
    }
  ],
  "require": {
    "php": ">=8.1",
    "composer/installers": "^2.0",
    "verysimple/vs-core": "^1.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/bekreative/vs-core"
    }
  ],
  "autoload": {
    "psr-4": {
      "Vs\\ReLink\\": "src/"
    }
  },
  "require-dev": {
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "squizlabs/php_codesniffer": "^3.0",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "package": "bash bin/package.sh"
  }
}
